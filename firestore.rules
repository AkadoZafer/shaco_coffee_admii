rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global kontrol: user dökümanını okuyup 'admin' rolünü doğrular
    function isAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Sadece admin üyeleri değiştirebilir
    match /users/{userId} {
      allow read, write: if isAdmin();
      
      // Kullanıcı kendi dökümanını okuyabilir
      allow read: if request.auth != null && request.auth.uid == userId;
      
      // Kullanıcı kendi dökümanını yaratabilir ama 'admin' rolünü koyamaz
      allow create: if request.auth != null 
                    && request.auth.uid == userId
                    && request.resource.data.role != 'admin';
                    
      // Kullanıcı dökümanını güncelleyebilir ama kritik alanlara DOKUNAMAZ!
      // role: Yetki yükseltme saldırısı engeli
      // balance: Bakiye manipülasyonu engeli
      // stars / tier: Sadakat programı hilesi engeli
      allow update: if request.auth != null 
                    && request.auth.uid == userId
                    && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'balance', 'stars', 'tier']));
    }

    match /menu/{document=**} {
      allow read: if true; // Tüm müşteriler görebilir
      allow write: if isAdmin(); // Sadece admin değiştirebilir
    }

    match /stories/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /campaigns/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /branches/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /settings/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Backend (Fastify Admin SDK) tarafından yönetilen koleksiyonlar
    // Client (Web App/Admin Panel) tarafında doğrudan Okuma/Yazma KESİNLİKLE YASAKTIR.
    match /qr_tokens/{document=**} {
      allow read, write: if false;
    }

    match /audit_logs/{document=**} {
       allow read: if isAdmin();
       allow write: if isAdmin();
    }

    // Sipariş koleksiyonu — kullanıcı kendi siparişlerini görebilir, admin hepsini görebilir
    match /orders/{orderId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /feedbacks/{id} {
      allow create: if request.auth != null;
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}
