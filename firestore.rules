rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isSelf(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if isSelf(userId) || isAdmin();

      allow create: if isSelf(userId)
        && (!request.resource.data.keys().hasAll(['role']) || request.resource.data.role != 'admin');

      allow update: if isSelf(userId)
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'balance', 'stars', 'tier']);

      allow delete: if isAdmin();
    }

    match /users/{document=**} {
      allow read: if isAdmin();
    }

    match /menu/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /stories/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /campaigns/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /branches/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /orders/{document=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /feedbacks/{docId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    match /categories/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Audit collection (legacy + current naming safe)
    match /auditLogs/{document=**} {
      allow read, write: if isAdmin();
    }

    match /audit_logs/{document=**} {
      allow read, write: if isAdmin();
    }

    match /transactions/{transactionId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Backend-only sensitive collection
    match /qr_tokens/{document=**} {
      allow read, write: if false;
    }

    // Firebase-native error tracking
    match /error_logs/{errorId} {
      // Admin panel listing
      allow read: if isAdmin();

      // App/Admin client create (backend Admin SDK rules bypass eder)
      allow create: if isSignedIn()
        && request.resource.data.keys().hasOnly([
          'source',
          'severity',
          'message',
          'stack',
          'route',
          'userId',
          'userAgent',
          'appVersion',
          'createdAt',
          'resolved'
        ])
        && request.resource.data.source in ['app', 'admin']
        && request.resource.data.severity in ['error', 'warning']
        && request.resource.data.message is string
        && request.resource.data.stack is string
        && request.resource.data.route is string
        && request.resource.data.userAgent is string
        && request.resource.data.appVersion is string
        && request.resource.data.createdAt is timestamp
        && request.resource.data.resolved == false
        && (
          !('userId' in request.resource.data)
          || request.resource.data.userId == null
          || request.resource.data.userId == request.auth.uid
        );

      // Admin only: resolved toggle
      allow update: if isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['resolved'])
        && request.resource.data.resolved is bool;

      allow delete: if false;
    }
  }
}

